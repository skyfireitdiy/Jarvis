    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动扩展",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/src/jarvis/jarvis_vscode_extension"
            ],
            "outFiles": [
                "${workspaceFolder}/src/jarvis/jarvis_vscode_extension/dist/**/*.js"
            ],
            "preLaunchTask": "npm: install-and-build",
            "cwd": "${workspaceFolder}/src/jarvis/jarvis_vscode_extension"
        }
    ]
}