{
  "name": "jarvis-vscode-extension",
  "displayName": "Jarvis",
  "description": "Jarvis VS Code extension with agent sidebar, chat panel and terminal panel.",
  "version": "0.0.1",
  "publisher": "jarvis",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:jarvis.agentListView",
    "onCommand:jarvis.openPanel",
    "onCommand:jarvis.refreshAgents"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jarvis.openPanel",
        "title": "Jarvis: Open Panel"
      },
      {
        "command": "jarvis.refreshAgents",
        "title": "Jarvis: Refresh Agents"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis",
          "title": "Jarvis",
          "icon": "media/jarvis.svg"
        }
      ]
    },
    "views": {
      "jarvis": [
        {
          "id": "jarvis.agentListView",
          "name": "Agents",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0"
  }
}
