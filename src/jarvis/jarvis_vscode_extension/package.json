{
  "name": "jarvis-vscode-extension",
  "displayName": "Jarvis",
  "description": "Jarvis VS Code extension with agent sidebar, chat panel and terminal panel.",
  "version": "0.0.1",
  "publisher": "jarvis",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/skyfireitdiy/Jarvis.git"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:jarvis.agentListView",
    "onCommand:jarvis.openPanel",
    "onCommand:jarvis.refreshAgents"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jarvis.openPanel",
        "title": "Jarvis: Open Panel"
      },
      {
        "command": "jarvis.refreshAgents",
        "title": "Jarvis: Refresh Agents"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis",
          "title": "Jarvis",
          "icon": "media/jarvis.svg"
        }
      ]
    },
    "views": {
      "jarvis": [
        {
          "id": "jarvis.agentListView",
          "name": "Agents",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build:webview": "esbuild ./src/webview/chatPanel.ts --bundle --format=iife --platform=browser --outfile=./media/chatPanel.js",
    "build": "npm run build:webview && tsc -p ./tsconfig.json",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.82.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0"
  }
}
